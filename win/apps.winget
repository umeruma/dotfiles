      settings:
        id: Anysphere.Cursor
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      directives:
        description: Claude
      settings:
        id: Anthropic.Claude
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      directives:
        description: Claude Code
      settings:
        id: Anthropic.ClaudeCode
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      directives:
        description: Slack
      settings:
        id: SlackTechnologies.Slack
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      directives:
        description: Unity Hub
      settings:
        id: Unity.UnityHub
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      directives:
        description: Zen Browser
      settings:
        id: Zen-Team.Zen-Browser
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      directives:
